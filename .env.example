# Server
JWT_SECRET=change-me-to-a-long-random-string
DATABASE_URL=mysql://user:password@localhost:3306/render_king
PORT=3000
SITE_URL=https://renderking.au

# Admin login (renderking.au/admin/blog)
ADMIN_EMAIL=admin@renderking.au
ADMIN_PASSWORD=change-me

# Owner notifications (defaults to admin@renderking.au)
OWNER_EMAIL=admin@renderking.au

# Email (Resend)
RESEND_API_KEY=

# Blog AI (OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional analytics
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
